{
  "name": "snake-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.5",
  "scripts": {
    "dev": "pnpm --filter @snake/web dev",
    "build": "pnpm --filter @snake/core build && pnpm --filter @snake/web build",
    "build:pages": "pnpm --filter @snake/core build && pnpm --filter @snake/web build",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test:unit": "pnpm --filter @snake/core test && pnpm --filter @snake/web test",
    "test:e2e": "playwright test",
    "test:e2e:pages": "playwright test -c playwright.pages.config.ts",
    "test:e2e:ui": "playwright test --ui --ui-host 127.0.0.1 --ui-port 9323",
    "test": "pnpm test:unit && pnpm test:e2e",
    "check": "pnpm lint && pnpm format:check && pnpm test:unit && pnpm build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@playwright/test": "^1.52.0",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.8.2"
  }
}
